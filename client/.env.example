# Client environment variables
# Rename to .env.local for local development

# API base URL (proxied through Vite dev server or Nginx in production)
VITE_API_URL=/api

# Socket.IO server URL (leave empty to use same origin)
VITE_SOCKET_URL=

# For development with separate backend
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=http://localhost:5000
